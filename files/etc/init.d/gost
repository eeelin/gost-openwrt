#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/gost
CONFIG=gost

validate_gost_section() {
	uci_validate_section gost gost "$1" \
		'enabled:bool:0' \
		'config_file:string' \
		'log_level:string'
}

start_instance() {
	local section="$1"
	local enabled config_file log_level

	validate_gost_section "$section" || return 1
	config_get_bool enabled "$section" enabled 0
	config_get config_file "$section" config_file '/etc/gost/config.yaml'
	config_get log_level "$section" log_level 'info'

	[ "$enabled" -eq 1 ] || return 0
	[ -x "$PROG" ] || return 1
	[ -f "$config_file" ] || {
		logger -t gost-init "missing config file: $config_file"
		return 1
	}

	procd_open_instance
	procd_set_param command "$PROG" -C "$config_file" -L "$log_level"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

start_service() {
	config_load "$CONFIG"
	config_foreach start_instance gost
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
